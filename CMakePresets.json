{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 19,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "hidden": true,
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/output/target",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug (Native)",
      "description": "本地 Debug 构建",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "ON",
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release (Native)",
      "description": "本地 Release 构建",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "ON",
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "arm32",
      "displayName": "ARM32 Cross-Compile",
      "description": "ARM32 (ARMv7-A) 交叉编译",
      "inherits": "default",
      "toolchainFile": "${sourceDir}/cmake/toolchains/arm32-linux-gnueabihf.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "OFF",
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "arm64",
      "displayName": "ARM64 Cross-Compile",
      "description": "ARM64 (ARMv8-A) 交叉编译",
      "inherits": "default",
      "toolchainFile": "${sourceDir}/cmake/toolchains/aarch64-linux-gnu.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "OFF",
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "riscv64",
      "displayName": "RISC-V 64 Cross-Compile",
      "description": "RISC-V 64 交叉编译",
      "inherits": "default",
      "toolchainFile": "${sourceDir}/cmake/toolchains/riscv64-linux-gnu.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "OFF",
        "BUILD_SHARED_LIBS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "displayName": "Build Debug",
      "description": "构建 Debug 版本"
    },
    {
      "name": "release",
      "configurePreset": "release",
      "displayName": "Build Release",
      "description": "构建 Release 版本"
    },
    {
      "name": "arm32",
      "configurePreset": "arm32",
      "displayName": "Build ARM32",
      "description": "构建 ARM32 版本"
    },
    {
      "name": "arm64",
      "configurePreset": "arm64",
      "displayName": "Build ARM64",
      "description": "构建 ARM64 版本"
    },
    {
      "name": "riscv64",
      "configurePreset": "riscv64",
      "displayName": "Build RISC-V 64",
      "description": "构建 RISC-V 64 版本"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "displayName": "Test Debug",
      "description": "运行 Debug 测试",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release",
      "configurePreset": "release",
      "displayName": "Test Release",
      "description": "运行 Release 测试",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
